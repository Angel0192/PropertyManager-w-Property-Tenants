@model PropertyManager.Models.Property

@{
    ViewData["Title"] = "Property Details";
}

<h1>Details for @Model.PropertyName</h1>

<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-3">Address</dt>
        <dd class="col-sm-9">@Model.Address</dd>

        <dt class="col-sm-3">Unit Number</dt>
        <dd class="col-sm-9">@Model.UnitNum</dd>

        <dt class="col-sm-3">Monthly Rent</dt>
        <dd class="col-sm-9">@Model.MonthlyRent.ToString("C")</dd>
    </dl>
</div>

<div class="mt-4">
    <h4>Current Tenants</h4>
    <table class="table table-sm">
        <thead>
            <tr>
                <th>Name</th>
                <th>Email</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Tenants != null && Model.Tenants.Any())
            {
                foreach (var tenant in Model.Tenants)
                {
                    <tr>
                        <td>@tenant.FirstName @tenant.LastName</td>
                        <td>@tenant.Email</td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="2" class="text-muted">No tenants assigned to this property.</td>
                </tr>
            }
        </tbody>
    </table>
</div>

<div class="mt-3">
    <a asp-action="Edit" asp-route-id="@Model.PropertyID" class="btn btn-warning">Edit</a>
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</div>