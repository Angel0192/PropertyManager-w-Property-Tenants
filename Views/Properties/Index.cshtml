@model IEnumerable<PropertyManager.Models.Property>

@{
    ViewData["Title"] = "Properties";
}

<h1>Properties</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Add New Property</a>
</p>

<table class="table">
    <thead>
        <tr>
            <th>Property Name</th>
            <th>Address</th>
            <th>Unit #</th>
            <th>Monthly Rent</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        
@foreach (var item in Model) {
        <tr>
            <td>@item.PropertyName</td>
            <td>@item.Address</td>
            <td>@item.UnitNum</td>
            <td>@item.MonthlyRent.ToString("C")</td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.PropertyID">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.PropertyID">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.PropertyID">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>