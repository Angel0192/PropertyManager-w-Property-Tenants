@model IEnumerable<PropertyManager.Models.Tenant>

@{
    ViewData["Title"] = "Tenants";
}

<h1>Tenants</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Add New Tenant</a>
</p>

<table class="table">
    <thead>
        <tr>
            <th>First Name</th>
            <th>Last Name</th>
            <th>Email</th>
            <th>Property</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>@item.FirstName</td>
            <td>@item.LastName</td>
            <td>@item.Email</td>
            <td>@item.Property?.PropertyName</td> <td>
                <a asp-action="Edit" asp-route-id="@item.TenantID">Edit</a> |
                <a asp-action="Delete" asp-route-id="@item.TenantID">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>