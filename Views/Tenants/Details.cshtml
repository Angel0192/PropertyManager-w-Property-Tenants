@model PropertyManager.Models.Tenant

@{
    ViewData["Title"] = "Property Details";
}

<h1>Details for @Model.FirstName @Model.LastName</h1>

<div>
    <hr />
    <dl class="row">
        <!-- Email -->
        <dt class="col-sm-3">Email:</dt>
        <dd class="col-sm-9">@Model.Email</dd>

        <!-- Phone Number -->
        <dt class="col-sm-3">Phone Number:</dt>
        <dd class="col-sm-9">@Model.PhoneNum</dd>

        <!-- Property -->
        <dt class="col-sm-3">Property:</dt>
        <dd class="col-sm-9">@(Model.Property?.PropertyName ?? "No Property Assigned")</dd>

    </dl>
</div>

<div class="mt-3">
    <a asp-action="Edit" asp-route-id="@Model.TenantID" class="btn btn-warning">Edit</a>
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</div>
