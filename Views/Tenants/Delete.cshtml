@model PropertyManager.Models.Tenant

<h1>Are you sure you want to delete this tenant?</h1>
<div>
    <dl class="row">
        <dt class="col-sm-2">Name</dt>
        <dd class="col-sm-10">@Model.FirstName @Model.LastName</dd>
        
        <dt class="col-sm-2">Property</dt>
        <dd class="col-sm-10">@Model.Property?.PropertyName</dd>
    </dl>
    
    <form asp-action="Delete">
        <input type="hidden" asp-for="TenantID" />
        <button type="submit" class="btn btn-danger">Delete Forever</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </form>
</div>